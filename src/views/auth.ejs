    <%# ================================================ %>
    <%# TAB: RESEND VERIFICATION %>
    <%# POST /auth/resend-verification — { email } %>
    <%# ================================================ %>
    <% if (locals.activeTab === 'resend') { %>

        <% if (locals.resendError) { %>
            <div class="alert alert-error"><%= resendError %></div>
        <% } %>
        <% if (locals.resendSuccess) { %>
            <div class="alert alert-success"><%= resendSuccess %></div>
        <% } %>

        <form action="/auth/resend-verification" method="POST" class="auth-form">
            <h2>Resend verification.</h2>

            <p style="color:var(--muted);font-size:13px;margin-bottom:4px">
                Enter your email and we'll send a new verification link.
            </p>

            <div class="field">
                <label for="resend-email">Email</label>
                <input id="resend-email" type="email" name="email"
                    placeholder="you@example.com"
                    value="<%= locals.resendEmail ?? '' %>"
                    required autocomplete="email">
            </div>

            <button type="submit" class="btn-primary">Send verification email →</button>

            <p style="text-align:center;color:var(--muted);font-size:13px">
                Already verified?
                <a href="/auth?activeTab=login">Sign in</a>
            </p>
        </form>

    <% } %>




    <%# ================================================ %>
    <%# TAB: REQUEST PASSWORD RESET %>
    <%# POST /auth/request-password-reset — { email } %>
    <%# ================================================ %>
    <% if (locals.activeTab === 'reset') { %>

        <% if (locals.resetReqError) { %>
            <div class="alert alert-error"><%= resetReqError %></div>
        <% } %>
        <% if (locals.resetReqSuccess) { %>
            <div class="alert alert-success"><%= resetReqSuccess %></div>
        <% } %>

        <form action="/auth/request-password-reset" method="POST" class="auth-form">
            <h2>Reset password.</h2>

            <p style="color:var(--muted);font-size:13px;margin-bottom:4px">
                Enter your email and we'll send a reset link.
            </p>

            <div class="field">
                <label for="reset-email">Email</label>
                <input id="reset-email" type="email" name="email"
                    placeholder="you@example.com"
                    value="<%= locals.resetReqEmail ?? '' %>"
                    required autocomplete="email">
            </div>

            <button type="submit" class="btn-primary">Send reset link →</button>

            <p style="text-align:center;color:var(--muted);font-size:13px">
                Remembered it?
                <a href="/auth?activeTab=login">Sign in</a>
            </p>
        </form>

    <% } %>

</div>

<%# JavaScript on this page does two things only: %>
<%# 1. Check if the two password fields match before submit %>
<%# 2. Update the phone placeholder when a country is selected %>
<%# No network calls, no fetch(). passwordConfirm is never sent to the server. %>
<script>
function checkPasswords() {
    const pw  = document.getElementById('reg-password');
    const pw2 = document.getElementById('reg-password-confirm');
    const msg = document.getElementById('pass-match-msg');
    if (!pw || !pw2 || !msg) return;

    if (pw2.value.length === 0) {
        msg.style.display = 'none';
        pw2.setCustomValidity('');
        return;
    }

    if (pw.value !== pw2.value) {
        msg.textContent   = 'Passwords do not match';
        msg.style.color   = 'var(--error)';
        msg.style.display = 'block';
        pw2.setCustomValidity('Passwords do not match');
    } else {
        msg.textContent   = '✓ Passwords match';
        msg.style.color   = 'var(--success)';
        msg.style.display = 'block';
        pw2.setCustomValidity('');
    }
}

function updatePhonePlaceholder() {
    const select = document.getElementById('countryCode');
    const phone  = document.getElementById('phone');
    if (!select || !phone) return;

    const selected = select.options[select.selectedIndex];
    const dial     = selected?.dataset?.dial ?? '';

    // Show the dial code as a hint, but the user types WITHOUT it
    // e.g. selecting Greece (+30) shows placeholder "6912345678"
    // The full number with dial code is assembled server-side by libphonenumber
    const examples = {
        '+1':   '2025550123',  '+7':   '9001234567',  '+20':  '1012345678',
        '+27':  '711234567',   '+30':  '6912345678',  '+31':  '612345678',
        '+32':  '470123456',   '+33':  '612345678',   '+34':  '612345678',
        '+36':  '201234567',   '+39':  '3123456789',  '+40':  '712345678',
        '+41':  '781234567',   '+43':  '6641234567',  '+44':  '7911123456',
        '+45':  '20123456',    '+46':  '701234567',   '+47':  '40123456',
        '+48':  '512345678',   '+49':  '15123456789', '+51':  '912345678',
        '+52':  '5512345678',  '+54':  '91123456789', '+55':  '11912345678',
        '+56':  '912345678',   '+57':  '3001234567',  '+60':  '123456789',
        '+61':  '412345678',   '+62':  '81234567890', '+63':  '9171234567',
        '+64':  '211234567',   '+65':  '81234567',    '+66':  '812345678',
        '+81':  '9012345678',  '+82':  '1012345678',  '+84':  '912345678',
        '+86':  '13123456789', '+90':  '5321234567',  '+91':  '9123456789',
        '+92':  '3001234567',  '+93':  '701234567',   '+234': '8012345678',
        '+254': '712345678',   '+351': '912345678',   '+352': '621123456',
        '+353': '851234567',   '+354': '6111234',     '+355': '672123456',
        '+356': '99123456',    '+357': '96123456',    '+358': '412345678',
        '+359': '48123456',    '+370': '61234567',    '+371': '21234567',
        '+372': '51234567',    '+380': '671234567',   '+381': '601234567',
        '+385': '912345678',   '+386': '31234567',    '+420': '601123456',
        '+421': '912123456',   '+54':  '91123456789', '+886': '912345678',
        '+966': '512345678',   '+971': '501234567',   '+972': '521234567',
    };

    if (dial && examples[dial]) {
        phone.placeholder = examples[dial];
    } else {
        phone.placeholder = '6912345678';
    }
}

// Set placeholder on page load if a country is already selected (e.g. after validation error)
document.addEventListener('DOMContentLoaded', updatePhonePlaceholder);
</script>