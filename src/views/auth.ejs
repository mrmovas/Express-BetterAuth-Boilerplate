<% locals.title = 'Login / Register' %>

<div class="auth-card">

    <%# Generic error (e.g. from middleware redirect) %>
    <% if (locals.error) { %>
        <div class="alert alert-error" style="margin-bottom:16px"><%= error %></div>
    <% } %>

    <%# These messages survive a tab switch (e.g. after signup → redirected to login tab) %>
    <%# They must live OUTSIDE the tab blocks so they always render %>
    <% if (locals.signupSuccess) { %>
        <div class="alert alert-success" style="margin-bottom:16px"><%= signupSuccess %></div>
    <% } %>
    <% if (locals.loginSuccess) { %>
        <div class="alert alert-success" style="margin-bottom:16px"><%= loginSuccess %></div>
    <% } %>


    <%# TABS — plain anchor links, no JS needed %>
    <div class="tabs">
        <a href="/auth?activeTab=login"
           class="tab <%= (!locals.activeTab || activeTab === 'login') ? 'active' : '' %>">
            Login
        </a>
        <a href="/auth?activeTab=register"
           class="tab <%= activeTab === 'register' ? 'active' : '' %>">
            Register
        </a>
        <a href="/auth?activeTab=resend"
           class="tab <%= activeTab === 'resend' ? 'active' : '' %>">
            Verify
        </a>
        <a href="/auth?activeTab=reset"
           class="tab <%= activeTab === 'reset' ? 'active' : '' %>">
            Reset
        </a>
    </div>




    <%# ================================================ %>
    <%# TAB: LOGIN %>
    <%# POST /auth/login — { email, password } %>
    <%# ================================================ %>
    <% if (!locals.activeTab || activeTab === 'login') { %>

        <% if (locals.loginError) { %>
            <div class="alert alert-error">
                <%= loginError %>
                <% if (locals.loginUnverified) { %>
                    &nbsp;·&nbsp;<a href="/auth?activeTab=resend" style="color:var(--error)">Resend verification email</a>
                <% } %>
            </div>
        <% } %>

        <form action="/auth/login" method="POST" class="auth-form">
            <h2>Welcome back.</h2>

            <div class="field">
                <label for="login-email">Email</label>
                <input id="login-email" type="email" name="email"
                    placeholder="you@example.com" required autocomplete="email">
            </div>

            <div class="field">
                <label for="login-password">Password</label>
                <input id="login-password" type="password" name="password"
                    placeholder="••••••••" required autocomplete="current-password">
            </div>

            <button type="submit" class="btn-primary">Sign in →</button>

            <p style="text-align:center;color:var(--muted);font-size:13px">
                Forgot your password?
                <a href="/auth?activeTab=reset">Reset it</a>
            </p>
        </form>

    <% } %>




    <%# ================================================ %>
    <%# TAB: REGISTER %>
    <%# POST /auth/signup — { email, password, firstName, lastName, phone: { countryCode, number } } %>
    <%# ================================================ %>
    <% if (locals.activeTab === 'register') { %>

        <% if (locals.signupError) { %>
            <div class="alert alert-error"><%= signupError %></div>
        <% } %>

        <form action="/auth/signup" method="POST" class="auth-form">
            <h2>Create account.</h2>

            <div class="row">
                <div class="field">
                    <label for="firstName">First name</label>
                    <input id="firstName" type="text" name="firstName"
                        placeholder="John"
                        value="<%= locals.signupFields?.firstName ?? '' %>"
                        required autocomplete="given-name">
                </div>
                <div class="field">
                    <label for="lastName">Last name</label>
                    <input id="lastName" type="text" name="lastName"
                        placeholder="Doe"
                        value="<%= locals.signupFields?.lastName ?? '' %>"
                        required autocomplete="family-name">
                </div>
            </div>

            <div class="field">
                <label for="reg-email">Email</label>
                <input id="reg-email" type="email" name="email"
                    placeholder="you@example.com"
                    value="<%= locals.signupFields?.email ?? '' %>"
                    required autocomplete="email">
            </div>

            <div class="field">
                <label for="reg-password">Password</label>
                <%# Password never repopulated — user must retype. Security best practice. %>
                <input id="reg-password" type="password" name="password"
                    placeholder="Min 8 chars, upper, lower, number, symbol"
                    required autocomplete="new-password"
                    oninput="checkPasswords()">
            </div>

            <div class="field">
                <label for="reg-password-confirm">Confirm password</label>
                <input id="reg-password-confirm" type="password" name="passwordConfirm"
                    placeholder="••••••••"
                    required autocomplete="new-password"
                    oninput="checkPasswords()">
                <span id="pass-match-msg" style="font-size:12px;display:none"></span>
            </div>

