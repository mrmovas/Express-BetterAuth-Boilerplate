<div class="auth-card">

    <% if (!isTokenValid) { %>

        <%# Token missing or invalid — don't show the form %>
        <div style="text-align:center">
            <div style="font-size:48px;margin-bottom:16px">✗</div>
            <h2 style="font-family:var(--serif);font-size:28px;margin-bottom:12px">Invalid link.</h2>
            <p style="color:var(--muted);margin-bottom:28px">
                This reset link is invalid. Please request a new one.
            </p>
            <a href="/auth?authType=reset-password" class="btn-primary">Request new reset link →</a>
        </div>

    <% } else if (locals.message && message.type === 'success') { %>

        <div style="text-align:center">
            <div style="font-size:48px;margin-bottom:16px">✓</div>
            <h2 style="font-family:var(--serif);font-size:28px;margin-bottom:12px">Password reset.</h2>
            <p style="color:var(--muted);margin-bottom:28px">
                Your password has been changed. You can now sign in.
            </p>
            <a href="/auth?authType=login" class="btn-primary">Sign in →</a>
        </div>

    <% } else { %>

        <% if (locals.message) { %>
            <div class="alert alert-<%= message.type %>" style="margin-bottom:16px"><%= message.text %></div>
        <% } %>

        <div id="reset-pass-msg"></div>

        <%# betterAuthClient.resetPassword({ newPassword, token }) %>
        <%# The token comes from the URL query param ?token=... set by better-auth %>
        <div class="auth-form">
            <h2>New password.</h2>

            <div class="field">
                <label for="new-password">New password</label>
                <input id="new-password" type="password"
                    placeholder="Min 8 chars, upper, lower, number, symbol"
                    autocomplete="new-password">
            </div>

            <button type="button" class="btn-primary" onclick="handleResetPassword()">Reset password →</button>
        </div>

    <% } %>

</div>

<script>
// ---------------------------------------------------------------------------
// RESET PASSWORD
// betterAuthClient.resetPassword({ newPassword, token })
// The token is read from the URL — better-auth puts it there via the email link.
// On success we reload so the server renders the success state via `message`.
// ---------------------------------------------------------------------------
async function handleResetPassword() {
    const msgEl      = document.getElementById('reset-pass-msg');
    const newPassword = document.getElementById('new-password').value;

    msgEl.className = '';
    msgEl.textContent = '';
    msgEl.style.marginBottom = '';

    if (!newPassword) {
        msgEl.className = 'alert alert-error';
        msgEl.textContent = 'Please enter a new password.';
        msgEl.style.marginBottom = '16px';
        return;
    }

    const token = new URLSearchParams(window.location.search).get('token') ?? '';

    const { data, error } = await betterAuthClient.resetPassword({
        newPassword,
        token,
    });

    if (error) {
        msgEl.className = 'alert alert-error';
        msgEl.textContent = error.message ?? 'Could not reset password.';
        msgEl.style.marginBottom = '16px';
    } else {
        // Reload so Express can render the success state via `message`
        window.location.reload();
    }
}
</script>
