<div class="auth-card">

    <% if (locals.message) { %>
        <div class="alert alert-<%= message.type %>" style="margin-bottom:16px"><%= message.text %></div>
    <% } %>


    <%# TABS %>
    <div class="tabs">
        <button type="button"
            class="tab <%= authType === 'login' ? 'active' : '' %>"
            onclick="showTab('login')">Login</button>
        <button type="button"
            class="tab <%= authType === 'register' ? 'active' : '' %>"
            onclick="showTab('register')">Register</button>
        <button type="button"
            class="tab <%= authType === 'verify-email' ? 'active' : '' %>"
            onclick="showTab('verify-email')">Verify</button>
        <button type="button"
            class="tab <%= authType === 'reset-password' ? 'active' : '' %>"
            onclick="showTab('reset-password')">Reset</button>
    </div>


    <%# ================================================ %>
    <%# TAB: LOGIN %>
    <%# betterAuthClient.signIn.email({ email, password }) %>
    <%# ================================================ %>
    <div id="tab-login" class="tab-panel" style="<%= authType === 'login' ? '' : 'display:none' %>">
        <div id="login-msg" class="tab-msg"></div>

        <div class="auth-form">
            <h2>Welcome back.</h2>

            <div class="field">
                <label for="login-email">Email</label>
                <input id="login-email" type="email"
                    placeholder="you@example.com" autocomplete="email">
            </div>

            <div class="field">
                <label for="login-password">Password</label>
                <input id="login-password" type="password"
                    placeholder="••••••••" autocomplete="current-password">
            </div>

            <button type="button" class="btn-primary" onclick="handleLogin()">Sign in →</button>

            <p style="text-align:center;color:var(--muted);font-size:13px">
                Forgot your password?
                <a href="#" onclick="showTab('reset-password')">Reset it</a>
            </p>
        </div>
    </div>


    <%# ================================================ %>
    <%# TAB: REGISTER %>
    <%# betterAuthClient.signUp.email({ email, password, name }) %>
    <%# better-auth uses a single `name` field; we join firstName + lastName %>
    <%# ================================================ %>
    <div id="tab-register" class="tab-panel" style="<%= authType === 'register' ? '' : 'display:none' %>">
        <div id="register-msg" class="tab-msg"></div>

        <div class="auth-form">
            <h2>Create account.</h2>

            <div class="row">
                <div class="field">
                    <label for="firstName">First name</label>
                    <input id="firstName" type="text"
                        placeholder="John" autocomplete="given-name">
                </div>
                <div class="field">
                    <label for="lastName">Last name</label>
                    <input id="lastName" type="text"
                        placeholder="Doe" autocomplete="family-name">
                </div>
            </div>

            <div class="field">
                <label for="reg-email">Email</label>
                <input id="reg-email" type="email"
                    placeholder="you@example.com" autocomplete="email">
            </div>

            <div class="field">
                <label for="reg-password">Password</label>
                <input id="reg-password" type="password"
                    placeholder="Min 8 chars, upper, lower, number, symbol"
                    autocomplete="new-password"
                    oninput="checkPasswords()">
            </div>

            <div class="field">
                <label for="reg-password-confirm">Confirm password</label>
                <input id="reg-password-confirm" type="password"
                    placeholder="••••••••"
                    autocomplete="new-password"
                    oninput="checkPasswords()">
                <span id="pass-match-msg" style="font-size:12px;display:none"></span>
            </div>

            <button type="button" class="btn-primary" onclick="handleRegister()">Create account →</button>

            <p style="text-align:center;color:var(--muted);font-size:13px">
                Already have an account?
                <a href="#" onclick="showTab('login')">Sign in</a>
            </p>
        </div>
    </div>


    <%# ================================================ %>
    <%# TAB: RESEND VERIFICATION %>
    <%# betterAuthClient.sendVerificationEmail({ email, callbackURL }) %>
    <%# ================================================ %>
    <div id="tab-verify-email" class="tab-panel" style="<%= authType === 'verify-email' ? '' : 'display:none' %>">
        <div id="verify-msg" class="tab-msg"></div>

        <div class="auth-form">
            <h2>Resend verification.</h2>

            <p style="color:var(--muted);font-size:13px;margin-bottom:4px">
                Enter your email and we'll send a new verification link.
            </p>

            <div class="field">
                <label for="resend-email">Email</label>
                <input id="resend-email" type="email"
                    placeholder="you@example.com" autocomplete="email">
            </div>

            <button type="button" class="btn-primary" onclick="handleResendVerification()">Send verification email →</button>

            <p style="text-align:center;color:var(--muted);font-size:13px">
                Already verified?
                <a href="#" onclick="showTab('login')">Sign in</a>
            </p>
        </div>
    </div>


    <%# ================================================ %>
    <%# TAB: REQUEST PASSWORD RESET %>
    <%# betterAuthClient.forgetPassword({ email, redirectTo }) %>
    <%# ================================================ %>
    <div id="tab-reset-password" class="tab-panel" style="<%= authType === 'reset-password' ? '' : 'display:none' %>">
        <div id="reset-msg" class="tab-msg"></div>

        <div class="auth-form">
            <h2>Reset password.</h2>

            <p style="color:var(--muted);font-size:13px;margin-bottom:4px">
                Enter your email and we'll send a reset link.
            </p>

            <div class="field">
                <label for="reset-email">Email</label>
                <input id="reset-email" type="email"
                    placeholder="you@example.com" autocomplete="email">
            </div>

            <button type="button" class="btn-primary" onclick="handleForgotPassword()">Send reset link →</button>

            <p style="text-align:center;color:var(--muted);font-size:13px">
                Remembered it?
                <a href="#" onclick="showTab('login')">Sign in</a>
            </p>
        </div>
    </div>

</div>

<script>
// ---------------------------------------------------------------------------
// Tab switching — no page reload
// ---------------------------------------------------------------------------
function showTab(name) {
    document.querySelectorAll('.tab-panel').forEach(p => p.style.display = 'none');
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    document.getElementById('tab-' + name).style.display = '';
    const order = ['login', 'register', 'verify-email', 'reset-password'];
    document.querySelectorAll('.tab')[order.indexOf(name)]?.classList.add('active');
}

// ---------------------------------------------------------------------------
// Message helpers
// ---------------------------------------------------------------------------
function showMsg(id, type, text) {
    const el = document.getElementById(id);
    el.className = 'tab-msg alert alert-' + type;
    el.textContent = text;
    el.style.marginBottom = '16px';
}
function clearMsg(id) {
    const el = document.getElementById(id);
    el.className = 'tab-msg';
    el.textContent = '';
    el.style.marginBottom = '';
}

// ---------------------------------------------------------------------------
// Password match check
// ---------------------------------------------------------------------------
function checkPasswords() {
    const pw  = document.getElementById('reg-password');
    const pw2 = document.getElementById('reg-password-confirm');
    const msg = document.getElementById('pass-match-msg');
    if (!pw || !pw2 || !msg) return;
    if (pw2.value.length === 0) { msg.style.display = 'none'; pw2.setCustomValidity(''); return; }
    if (pw.value !== pw2.value) {
        msg.textContent = 'Passwords do not match'; msg.style.color = 'var(--error)';
        msg.style.display = 'block'; pw2.setCustomValidity('Passwords do not match');
    } else {
        msg.textContent = '✓ Passwords match'; msg.style.color = 'var(--success)';
        msg.style.display = 'block'; pw2.setCustomValidity('');
    }
}

// ---------------------------------------------------------------------------
// LOGIN
// betterAuthClient.signIn.email({ email, password })
// ---------------------------------------------------------------------------
async function handleLogin() {
    clearMsg('login-msg');
    const email    = document.getElementById('login-email').value.trim();
    const password = document.getElementById('login-password').value;
    if (!email || !password) return showMsg('login-msg', 'error', 'Please fill in all fields.');

    const { data, error } = await betterAuthClient.signIn.email({ email, password });

    if (error) return showMsg('login-msg', 'error', error.message ?? 'Sign in failed.');
    window.location.href = '/profile';
}

// ---------------------------------------------------------------------------
// REGISTER
// betterAuthClient.signUp.email({ email, password, name })
// better-auth uses a single `name` field — we join firstName + lastName here.
// If your server plugin splits them, pass extra fields in the `...rest` spread.
// ---------------------------------------------------------------------------
async function handleRegister() {
    clearMsg('register-msg');
    const firstName = document.getElementById('firstName').value.trim();
    const lastName  = document.getElementById('lastName').value.trim();
    const email     = document.getElementById('reg-email').value.trim();
    const password  = document.getElementById('reg-password').value;
    const confirm   = document.getElementById('reg-password-confirm').value;

    if (!firstName || !lastName || !email || !password || !confirm)
        return showMsg('register-msg', 'error', 'Please fill in all fields.');
    if (password !== confirm)
        return showMsg('register-msg', 'error', 'Passwords do not match.');

    const { data, error } = await betterAuthClient.signUp.email({
        email,
        password,
        name: `${firstName} ${lastName}`,
    });

    if (error) return showMsg('register-msg', 'error', error.message ?? 'Registration failed.');
    showMsg('register-msg', 'success', 'Account created! Please check your email to verify.');
}

// ---------------------------------------------------------------------------
// RESEND VERIFICATION EMAIL
// betterAuthClient.sendVerificationEmail({ email, callbackURL })
// callbackURL is the route that handles the ?token= link from the email.
// ---------------------------------------------------------------------------
async function handleResendVerification() {
    clearMsg('verify-msg');
    const email = document.getElementById('resend-email').value.trim();
    if (!email) return showMsg('verify-msg', 'error', 'Please enter your email.');

    const { data, error } = await betterAuthClient.sendVerificationEmail({
        email,
        callbackURL: '/verify-email',
    });

    if (error) return showMsg('verify-msg', 'error', error.message ?? 'Could not send email.');
    showMsg('verify-msg', 'success', 'Verification email sent! Check your inbox.');
}

// ---------------------------------------------------------------------------
// FORGOT PASSWORD
// betterAuthClient.forgetPassword({ email, redirectTo })
// redirectTo is the page better-auth appends ?token= to inside the email link.
// ---------------------------------------------------------------------------
async function handleForgotPassword() {
    clearMsg('reset-msg');
    const email = document.getElementById('reset-email').value.trim();
    if (!email) return showMsg('reset-msg', 'error', 'Please enter your email.');

    const { data, error } = await betterAuthClient.forgetPassword({
        email,
        redirectTo: '/reset-password',
    });

    if (error) return showMsg('reset-msg', 'error', error.message ?? 'Could not send email.');
    showMsg('reset-msg', 'success', 'Reset link sent! Check your inbox.');
}
</script>
