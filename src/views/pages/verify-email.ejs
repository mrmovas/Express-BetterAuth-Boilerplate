<div class="auth-card" style="text-align:center">

    <% if (locals.message && message.type === 'success') { %>

        <div style="font-size:48px;margin-bottom:16px">✓</div>
        <h2 style="font-family:var(--serif);font-size:28px;margin-bottom:12px">
            Email verified.
        </h2>
        <p style="color:var(--muted);margin-bottom:28px">
            Your account is now active. You can sign in.
        </p>
        <a href="/auth?authType=login" class="btn-primary">Sign in →</a>

    <% } else { %>

        <div style="font-size:48px;margin-bottom:16px">✗</div>
        <h2 style="font-family:var(--serif);font-size:28px;margin-bottom:12px">
            Verification failed.
        </h2>

        <% if (locals.message) { %>
            <%# Server can set message.text to explain the exact reason (expired, already used, etc.) %>
            <p style="color:var(--muted);margin-bottom:28px"><%= message.text %></p>
        <% } else { %>
            <p style="color:var(--muted);margin-bottom:28px">
                This verification link is invalid or has already been used.
            </p>
        <% } %>

        <a href="/auth?authType=verify-email" class="btn-primary">Resend verification →</a>

    <% } %>

</div>
