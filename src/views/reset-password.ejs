<%# views/reset-password.ejs %>
<%# User lands here from the link in their email: GET /reset-password?token=... %>
<%# The token moves from the URL query param into a hidden form field. %>
<%# The POST sends it in the body — never in the URL of a POST request. %>
<% locals.title = 'Reset Password' %>

<div class="auth-card">

    <% if (!locals.validToken) { %>

        <%# Token missing or wrong length — don't even show the form %>
        <div style="text-align:center">
            <div style="font-size:48px;margin-bottom:16px">✗</div>
            <h2 style="font-family:var(--serif);font-size:28px;margin-bottom:12px">Invalid link.</h2>
            <p style="color:var(--muted);margin-bottom:28px">
                This reset link is invalid. Please request a new one.
            </p>
            <a href="/auth?activeTab=reset" class="btn-primary">Request new reset link →</a>
        </div>

    <% } else if (locals.success) { %>

        <div style="text-align:center">
            <div style="font-size:48px;margin-bottom:16px">✓</div>
            <h2 style="font-family:var(--serif);font-size:28px;margin-bottom:12px">Password reset.</h2>
            <p style="color:var(--muted);margin-bottom:28px">
                Your password has been changed. You can now sign in.
            </p>
            <a href="/auth?activeTab=login" class="btn-primary">Sign in →</a>
        </div>

    <% } else { %>

        <% if (locals.error) { %>
            <div class="alert alert-error" style="margin-bottom:16px"><%= error %></div>
        <% } %>

        <%# POST /auth/reset-password — { token (hidden), password } %>
        <form action="/auth/reset-password" method="POST" class="auth-form">
            <h2>New password.</h2>

            <%# Token travels in the body — never in the POST URL %>
            <input type="hidden" name="token" value="<%= token %>">

            <div class="field">
                <label for="new-password">New password</label>
                <input id="new-password" type="password" name="password"
                    placeholder="Min 8 chars, upper, lower, number, symbol"
                    required autocomplete="new-password">
            </div>

            <button type="submit" class="btn-primary">Reset password →</button>
        </form>

    <% } %>

</div>
