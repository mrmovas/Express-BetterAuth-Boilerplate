<%# views/verify-email.ejs %>
<%# User lands here from the link in their email: GET /verify-email?token=... %>
<%# The controller has already run the verification — we just show the result. %>
<% locals.title = 'Email Verification' %>

<div class="auth-card" style="text-align:center">

    <% if (locals.success) { %>

        <div style="font-size:48px;margin-bottom:16px">✓</div>
        <h2 style="font-family:var(--serif);font-size:28px;margin-bottom:12px">
            Email verified.
        </h2>
        <p style="color:var(--muted);margin-bottom:28px">
            Your account is now active. You can sign in.
        </p>
        <a href="/auth?activeTab=login" class="btn-primary">Sign in →</a>

    <% } else { %>

        <div style="font-size:48px;margin-bottom:16px">✗</div>
        <h2 style="font-family:var(--serif);font-size:28px;margin-bottom:12px">
            Verification failed.
        </h2>

        <% if (locals.reason === 'EXPIRED_TOKEN') { %>
            <p style="color:var(--muted);margin-bottom:28px">
                This link has expired. Request a new one below.
            </p>
            <a href="/auth?activeTab=resend" class="btn-primary">Resend verification →</a>

        <% } else if (locals.reason === 'TOKEN_REUSE') { %>
            <p style="color:var(--muted);margin-bottom:28px">
                This link has already been used. If your account is still unverified, request a new link.
            </p>
            <a href="/auth?activeTab=resend" class="btn-primary">Resend verification →</a>

        <% } else { %>
            <p style="color:var(--muted);margin-bottom:28px">
                This verification link is invalid or has already been used.
            </p>
            <a href="/auth?activeTab=resend" class="btn-primary">Resend verification →</a>

        <% } %>

    <% } %>

</div>
