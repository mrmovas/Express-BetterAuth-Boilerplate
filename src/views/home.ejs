<%# views/home.ejs %>
<% locals.title = 'Home' %>

<div class="hero">
    <div class="badge">auth boilerplate</div>

    <h1>
        Your app<br>
        <em>starts here.</em>
    </h1>

    <p class="sub">
        A minimal Express + EJS SSR auth setup.
        Register, verify your email, and access your profile.
    </p>

    <div class="actions">
        <% if (locals.user) { %>
            <p style="color:var(--muted)">Welcome back, <strong style="color:var(--text)"><%= user.firstName %></strong></p>
            <a href="/profile" class="btn-primary">Go to profile →</a>
            <form action="/logout" method="POST" style="display:inline">
                <button type="submit" class="btn-ghost">Logout</button>
            </form>
        <% } else { %>
            <a href="/auth" class="btn-primary">Get started →</a>
            <a href="/auth" class="btn-ghost">Login</a>
        <% } %>
    </div>

    <div class="stack">
        <span>Express</span> · <span>EJS</span> · <span>PostgreSQL</span> · <span>Prisma</span>
    </div>
</div>
