<%# views/profile.ejs %>
<% locals.title = 'Profile' %>

<div style="display:flex;flex-direction:column;gap:24px;width:100%;max-width:480px">

    <%# PROFILE CARD %>
    <div class="profile-card">

        <div class="profile-header">
            <div class="avatar">
                <%= user.firstName[0].toUpperCase() %><%= user.lastName[0].toUpperCase() %>
            </div>
            <div>
                <h1><%= user.firstName %> <%= user.lastName %></h1>
                <span class="role-badge"><%= user.role %></span>
            </div>
        </div>

        <div class="divider"></div>

        <% if (locals.error) { %>
            <div class="alert alert-error" style="margin-bottom:16px"><%= error %></div>
        <% } %>
        <% if (locals.success) { %>
            <div class="alert alert-success" style="margin-bottom:16px"><%= success %></div>
        <% } %>

        <dl class="info-grid">
            <dt>Email</dt>
            <dd><%= user.email %></dd>

            <dt>Email verified</dt>
            <dd>
                <% if (user.emailVerified) { %>
                    <span style="color:var(--success)">✓ Verified</span>
                <% } else { %>
                    <span style="color:var(--error)">✗ Not verified</span>
                    &nbsp;·&nbsp;
                    <a href="/auth?activeTab=resend">Resend link</a>
                <% } %>
            </dd>

            <dt>User ID</dt>
            <dd class="mono"><%= user.id %></dd>

            <dt>Member since</dt>
            <dd>
                <%= new Date(user.createdAt).toLocaleDateString('en-GB', {
                    day: 'numeric', month: 'long', year: 'numeric'
                }) %>
            </dd>
        </dl>

        <div class="divider"></div>

        <form action="/logout" method="POST">
            <button type="submit" class="btn-logout">Sign out</button>
        </form>

    </div>


    <%# CHANGE PASSWORD CARD %>
    <div class="profile-card">
        <h2 style="font-family:var(--serif);font-size:22px;margin-bottom:20px">Change password</h2>

        <% if (locals.changePassError) { %>
            <div class="alert alert-error" style="margin-bottom:16px"><%= changePassError %></div>
        <% } %>
        <% if (locals.changePassSuccess) { %>
            <div class="alert alert-success" style="margin-bottom:16px"><%= changePassSuccess %></div>
        <% } %>

        <%# POST /auth/change-password — { oldPassword, newPassword } %>
        <form action="/auth/change-password" method="POST" class="auth-form">

            <div class="field">
                <label for="oldPassword">Current password</label>
                <input id="oldPassword" type="password" name="oldPassword"
                    placeholder="••••••••" required autocomplete="current-password">
            </div>

            <div class="field">
                <label for="newPassword">New password</label>
                <input id="newPassword" type="password" name="newPassword"
                    placeholder="Min 8 chars, upper, lower, number, symbol"
                    required autocomplete="new-password">
            </div>

            <button type="submit" class="btn-primary">Change password →</button>
        </form>
    </div>

</div>
