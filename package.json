{
    "name": "express-betterauth-boilerplate",
    "version": "1.3.5",
    "description": "Production-ready Express & TypeScript boilerplate featuring Better-Auth, Kysely, and PostgreSQL with a clean, type-safe architecture.",
    "main": "./dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc && tsc-alias",
        "db:codegen": "kysely-codegen --out-file ./src/types/database.types.ts --dialect postgres",
        "db:better-auth:migrate": "npx auth@1.6.10 migrate",
        "start": "node dist/index.js",
        "typecheck": "tsc --noEmit"
    },
    "keywords": [],
    "author": "mrmovas",
    "license": "MIT",
    "type": "commonjs",
    "dependencies": {
        "better-auth": "^1.6.10",
        "compression": "^1.8.1",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "express-rate-limit": "^8.5.1",
        "helmet": "^8.1.0",
        "kysely": "^0.29.0",
        "morgan": "^1.10.1",
        "nodemailer": "^8.0.5",
        "pg": "^8.20.0",
        "uuid": "^13.0.0",
        "winston": "^3.19.0",
        "winston-daily-rotate-file": "^5.0.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/compression": "^1.8.1",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/morgan": "^1.9.10",
        "@types/node": "^25.6.2",
        "@types/nodemailer": "^8.0.0",
        "@types/pg": "^8.20.0",
        "kysely-codegen": "^0.20.0",
        "tsc-alias": "^1.8.16",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2"
    }
}
